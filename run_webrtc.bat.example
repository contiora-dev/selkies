@echo off
setlocal enabledelayedexpansion

:: =============================================================
::  Selkies WebRTC Mode Launcher for Windows
::  Copy this script to your project root and edit the settings.
::  You need:
::    1. MSYS2/MinGW64 with GStreamer + PyGObject installed
::    2. Python venv with project dependencies
::    3. SSL certificate for HTTPS (self-signed for LAN use)
:: =============================================================

:: -- Auto-detect project root (where this .bat lives) --
set "PROJECT_ROOT=%~dp0"
:: Remove trailing backslash
if "%PROJECT_ROOT:~-1%"=="\" set "PROJECT_ROOT=%PROJECT_ROOT:~0,-1%"

:: -- Auto-detect local IP --
for /f "tokens=2 delims=:" %%a in ('ipconfig ^| findstr /c:"IPv4"') do (
    for /f "tokens=1" %%b in ("%%a") do set "LOCAL_IP=%%b"
)
if not defined LOCAL_IP set "LOCAL_IP=127.0.0.1"

:: -- Auto-detect Python in venv --
if exist "%PROJECT_ROOT%\.venv\Scripts\python.exe" (
    set "PYTHON=%PROJECT_ROOT%\.venv\Scripts\python.exe"
) else if exist "%PROJECT_ROOT%\.venv\bin\python.exe" (
    set "PYTHON=%PROJECT_ROOT%\.venv\bin\python.exe"
) else (
    echo ERROR: No Python venv found at %PROJECT_ROOT%\.venv
    echo Create one with: python -m venv .venv
    pause
    exit /b 1
)

:: -- Auto-detect SSL cert/key --
set "SSL_CERT="
set "SSL_KEY="
if exist "%PROJECT_ROOT%\selkies-dev-cert.pem" set "SSL_CERT=%PROJECT_ROOT%\selkies-dev-cert.pem"
if exist "%PROJECT_ROOT%\selkies-dev-key.pem" set "SSL_KEY=%PROJECT_ROOT%\selkies-dev-key.pem"

:: ============= USER SETTINGS =============
:: Uncomment and edit these to override defaults:

set SELKIES_MODE=webrtc
set SELKIES_WEB_ROOT=%PROJECT_ROOT%\addons\selkies-web-core\dist
set SELKIES_ADDR=0.0.0.0
set SELKIES_PORT=8081
set SELKIES_ENCODER_RTC=x264enc
set SELKIES_ENABLE_BASIC_AUTH=false

:: Resolution (0 = auto-detect desktop resolution)
set SELKIES_MANUAL_WIDTH=1920
set SELKIES_MANUAL_HEIGHT=1080

:: Streaming quality
set SELKIES_AUDIO_ENABLED=true
set SELKIES_FRAMERATE=30
set SELKIES_VIDEO_BITRATE=8
set SELKIES_DEBUG=true

:: HTTPS (required for non-localhost browser access)
set SELKIES_ENABLE_HTTPS=true
:: SELKIES_HTTPS_CERT and SELKIES_HTTPS_KEY are auto-detected above
:: To generate a self-signed cert, see the instructions below.
:: ============= END USER SETTINGS =============

:: -- Apply SSL settings --
if defined SSL_CERT set "SELKIES_HTTPS_CERT=%SSL_CERT%"
if defined SSL_KEY set "SELKIES_HTTPS_KEY=%SSL_KEY%"

if "%SELKIES_ENABLE_HTTPS%"=="true" (
    if not defined SELKIES_HTTPS_CERT (
        echo.
        echo WARNING: HTTPS is enabled but no certificate found.
        echo Generate a self-signed cert with PowerShell:
        echo.
        echo   $cert = New-SelfSignedCertificate -DnsName "%LOCAL_IP%","localhost" -CertStoreLocation "Cert:\CurrentUser\My" -FriendlyName "Selkies Dev" -NotAfter ^(Get-Date^).AddYears^(5^)
        echo   $pwd = ConvertTo-SecureString "selkies" -AsPlainText -Force
        echo   Export-PfxCertificate -Cert $cert -FilePath "selkies-dev.pfx" -Password $pwd
        echo   Then export PEM key+cert from the PFX using openssl.
        echo.
        pause
        exit /b 1
    )
)

set PYTHONPATH=%PROJECT_ROOT%\src

echo ============================================================
echo  Selkies WebRTC - Windows Launcher
echo ============================================================
echo  Project:  %PROJECT_ROOT%
echo  Python:   %PYTHON%
echo  Access:   http%SELKIES_ENABLE_HTTPS:s%://127.0.0.1:%SELKIES_PORT%
echo  LAN:      http%SELKIES_ENABLE_HTTPS:s%://%LOCAL_IP%:%SELKIES_PORT%
echo  Encoder:  %SELKIES_ENCODER_RTC%
echo  Audio:    %SELKIES_AUDIO_ENABLED%
echo  Resolution: %SELKIES_MANUAL_WIDTH%x%SELKIES_MANUAL_HEIGHT%
echo ============================================================
echo.

"%PYTHON%" -m selkies
